# EDMG Studio (Desktop) runtime env defaults

# Backend
EDMG_STUDIO_DATA_DIR=./data
EDMG_STUDIO_BACKEND_HOST=127.0.0.1
EDMG_STUDIO_BACKEND_PORT=7863

# AI (default: local Ollama)
EDMG_AI_MODE=local
EDMG_AI_PROVIDER=ollama
EDMG_AI_OLLAMA_URL=http://127.0.0.1:11434
EDMG_AI_OLLAMA_MODEL=qwen2.5:3b-instruct

# ComfyUI
EDMG_COMFYUI_URL=http://127.0.0.1:8188
# Multi-node example:
# EDMG_COMFYUI_URLS=http://127.0.0.1:8188,http://192.168.1.50:8188

# FFmpeg (Option B): install FFmpeg and ensure it's on PATH, or set EDMG_FFMPEG_PATH to the ffmpeg executable.
EDMG_FFMPEG_PATH=ffmpeg

# Optional tokens (recommended to set via Studio Settings → Tokens)
# HF_TOKEN=
# CIVITAI_API_KEY=
